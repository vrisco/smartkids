{
  "name": "@smartkids/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply smartkids --local",
    "db:seed": "wrangler d1 execute smartkids --local --file=./seed.sql",
    "admin": "node scripts/admin.mjs"
  },
  "dependencies": {
    "@smartkids/shared": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "drizzle-kit": "^0.30.0",
    "wrangler": "^3.90.0"
  }
}
